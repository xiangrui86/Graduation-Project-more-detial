# ========================= 系统通用文件（保留你的原有规则） =========================
# OS 临时文件
.DS_Store
Thumbs.db

# 日志文件
*.log
logs/

# 构建产物（后端+通用）
target/
build/
out/

# Maven 缓存
.mvn/timing.properties

# Gradle 缓存
.gradle/

# IDEA 配置（后端开发常用）
.idea/
*.iml
*.iws

# VS Code 配置（前端开发常用）
.vscode/

# 环境变量文件（敏感信息，绝对不提交）
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.swp
*~

# Java 编译产物
*.class

# Java 包文件
*.jar
*.war
*.ear

# 测试覆盖率报告
coverage/

# ========================= 新增：前端 Vue 项目专属规则（核心补充） =========================
# npm 依赖包（前端体积大头，必须忽略）
frontend/node_modules/
# Vue 打包后的生产代码
frontend/dist/
# Vue CLI 缓存
frontend/.cache/
# npm 依赖锁文件（可选：单人项目可忽略，多人协作建议提交）
frontend/package-lock.json
frontend/yarn.lock
# 前端构建临时文件
frontend/*.js.map
frontend/*.css.map

# ========================= 优化：路径精准化（避免误忽略） =========================
# 仅忽略后端根目录的 target（如果有多个模块，可补充 module/target/）
backend/target/
# 仅忽略后端的 jar/war 包
backend/*.jar
backend/*.war